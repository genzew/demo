<wxs src="../../wxs/format.wxs" module="f" />
<view class="store-card" bindtap="onTap">
  <image class="cover" src="{{ store.cover }}" mode="aspectFill" />
  <view class="content">
    <view class="title text-ellipsis">{{ store.name }}</view>
    <view class="row meta">
      <text class="rating">★ {{ store.rating }}</text>
      <text class="muted">{{ store.ratingCount }}评</text>
      <text class="muted dot">·</text>
      <text class="muted" wx:if="{{ store.distance != null }}">{{ f.distance(store.distance) }}</text>
    </view>
    <view class="row tags">
      <van-tag wx:for="{{ store.tags }}" wx:key="*this" plain type="primary" custom-class="tag-item">{{ item }}</van-tag>
    </view>
    <view class="row-between footer">
      <view class="address text-ellipsis">{{ store.address }}</view>
      <view class="price">
        <text class="symbol">¥</text>
        <text class="num">{{ f.yuan(store.minPrice, 0) }}</text>
        <text class="muted">/小时起</text>
      </view>
    </view>
  </view>
</view>
