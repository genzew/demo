<wxs src="../../wxs/format.wxs" module="f" />
<view class="page order-list">
  <van-tabs active="{{ activeTab }}" sticky bind:change="onTabChange">
    <van-tab wx:for="{{ tabs }}" wx:key="key" title="{{ item.name }}" />
  </van-tabs>

  <block wx:if="{{ loading }}">
    <view class="card" wx:for="{{ [1, 2, 3] }}" wx:key="*this">
      <van-skeleton title row="3" loading />
    </view>
  </block>
  <block wx:elif="{{ list.length === 0 }}">
    <empty-state text="暂无订单" />
  </block>
  <block wx:else>
    <view class="card order-card" wx:for="{{ list }}" wx:key="orderId" data-id="{{ item.orderId }}" bindtap="goDetail">
      <view class="row-between">
        <view class="text-ellipsis store-name">{{ item.storeName }}</view>
        <view class="status status-{{ item.status }}">{{ statusLabel[item.status] }}</view>
      </view>
      <view class="muted text-ellipsis room">{{ item.roomName }} · {{ item.hours }}小时</view>
      <view class="muted text-ellipsis time">{{ item.date }} {{ item.startTime }} - {{ item.endTime }}</view>
      <view class="row-between footer">
        <view class="amount">实付 ¥{{ f.yuan(item.payAmount) }}</view>
        <view class="actions">
          <van-button
            wx:if="{{ item.status === 'pending_pay' }}"
            size="small"
            type="primary"
            data-id="{{ item.orderId }}"
            catchtap="goDetail"
          >继续支付</van-button>
          <van-button
            wx:if="{{ item.status === 'paid' || item.status === 'in_use' }}"
            size="small"
            type="primary"
            data-id="{{ item.orderId }}"
            catchtap="onOpen"
          >开门</van-button>
          <van-button
            wx:if="{{ item.status === 'pending_pay' || item.status === 'paid' }}"
            size="small"
            plain
            data-id="{{ item.orderId }}"
            catchtap="onCancel"
            custom-style="margin-left: 12rpx;"
          >取消</van-button>
        </view>
      </view>
    </view>
  </block>
</view>
