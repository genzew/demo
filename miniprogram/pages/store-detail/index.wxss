.gallery { width: 100%; height: 480rpx; }
.gallery-img { width: 100%; height: 100%; }

.title { font-size: 36rpx; font-weight: 700; }
.meta { gap: 12rpx; margin-top: 8rpx; }
.rating { color: #ff8a3d; font-weight: 500; }
.tags { gap: 8rpx; flex-wrap: wrap; margin-top: 12rpx; }
.tag-item { margin-right: 8rpx; }

.action-row { padding: 16rpx 0; border-top: 1rpx solid var(--gray-3); margin-top: 16rpx; }
.addr-block { gap: 8rpx; flex: 1; }
.addr-text { font-size: 26rpx; color: #323233; margin-left: 8rpx; }
.distance { color: #1989fa; font-size: 24rpx; }
.phone { margin-left: 8rpx; color: #1989fa; }

.intro { font-size: 26rpx; line-height: 1.7; color: #323233; }

.rooms { padding: 0 20rpx 20rpx; }
.room-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.room-img { width: 220rpx; height: 220rpx; flex-shrink: 0; }
.room-content { flex: 1; padding: 16rpx 20rpx; display: flex; flex-direction: column; justify-content: space-between; }
.room-name { font-size: 30rpx; font-weight: 600; }
.room-status { font-size: 22rpx; padding: 2rpx 10rpx; border-radius: 6rpx; }
.status-idle  { color: #07c160; background: rgba(7, 193, 96, 0.1); }
.status-busy  { color: #969799; background: var(--gray-3); }
.footer { margin-top: 12rpx; }
.price .symbol { color: #ee0a24; font-size: 22rpx; }
.price .num { color: #ee0a24; font-size: 32rpx; font-weight: 600; margin: 0 4rpx; }
