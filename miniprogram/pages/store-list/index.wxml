<view class="page store-list">
  <van-search
    value="{{ keyword }}"
    placeholder="搜索门店、地址"
    shape="round"
    bind:search="onSearch"
    bind:clear="onSearch"
  />
  <view class="sort-bar">
    <view
      wx:for="{{ sortOptions }}"
      wx:key="value"
      class="sort-item {{ sort === item.value ? 'active' : '' }}"
      data-value="{{ item.value }}"
      bindtap="onSortChange"
    >{{ item.name }}</view>
  </view>

  <block wx:if="{{ loading }}">
    <view class="card" wx:for="{{ [1, 2, 3] }}" wx:key="*this">
      <van-skeleton title row="3" loading />
    </view>
  </block>
  <block wx:elif="{{ list.length === 0 }}">
    <empty-state text="暂无符合条件的门店" />
  </block>
  <block wx:else>
    <store-card wx:for="{{ list }}" wx:key="id" store="{{ item }}" bind:tap="onStoreTap" />
  </block>
</view>
