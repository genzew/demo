<view class="page success" wx:if="{{ order }}">
  <view class="hero">
    <van-icon name="checked" size="120rpx" color="#07c160" />
    <view class="title">支付成功</view>
    <view class="subtitle">已为你保留包厢，请按时到店</view>
  </view>

  <view class="card info">
    <view class="row-between info-row"><text class="label">订单号</text><text>{{ order.orderId }}</text></view>
    <view class="row-between info-row"><text class="label">门店</text><text>{{ order.storeName }}</text></view>
    <view class="row-between info-row"><text class="label">包厢</text><text>{{ order.roomName }}</text></view>
    <view class="row-between info-row"><text class="label">时间</text><text>{{ order.date }} {{ order.startTime }} - {{ order.endTime }}</text></view>
    <view class="row-between info-row"><text class="label">实付</text><text class="amount">¥{{ (order.payAmount / 100).toFixed(2) }}</text></view>
  </view>

  <view class="actions">
    <van-button type="primary" block round bindtap="goDetail">查看订单 / 开门</van-button>
    <view style="height: 24rpx;"></view>
    <van-button plain block round bindtap="goHome">返回首页</van-button>
  </view>
</view>
