.room-summary { display: flex; align-items: center; }
.room-img { width: 160rpx; height: 160rpx; border-radius: 12rpx; }
.ml { margin-left: 20rpx; min-width: 0; }
.room-summary .title { font-size: 30rpx; font-weight: 600; }
.room-summary .price { margin-top: 8rpx; }
.room-summary .symbol { color: #ee0a24; font-size: 22rpx; }
.room-summary .num { color: #ee0a24; font-size: 30rpx; font-weight: 600; margin: 0 4rpx; }

.time-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 12rpx;
}
.time-chip {
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  background: var(--gray-1);
  color: #323233;
  font-size: 24rpx;
}
.time-chip.active {
  background: var(--primary-color);
  color: #fff;
}

.tag-item { margin-right: 8rpx; }

.occupied-card { background: #fff7ed; }

.coupon-popup { padding: 24rpx; max-height: 70vh; overflow: auto; }
.popup-title { font-size: 32rpx; font-weight: 600; padding-bottom: 16rpx; }
.coupon-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx dashed var(--gray-3);
}
.coupon-row .amount { width: 140rpx; text-align: center; }
.coupon-row .symbol { color: #ee0a24; font-size: 22rpx; }
.coupon-row .num { color: #ee0a24; font-size: 44rpx; font-weight: 700; }
.coupon-row .title { font-weight: 500; }
.coupon-clear { text-align: center; padding: 24rpx; color: #969799; }
