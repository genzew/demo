.head { text-align: center; padding: 32rpx; }
.store { font-size: 32rpx; font-weight: 600; }

.circle-wrap { display: flex; justify-content: center; padding: 80rpx 0; }
.circle {
  width: 440rpx;
  height: 440rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1989fa, #4caefb);
  color: #fff;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 0 12rpx 40rpx rgba(25, 137, 250, 0.3);
  transition: transform .3s;
}
.circle:active { transform: scale(0.96); }
.circle.opening { animation: pulse 1.2s infinite; }
.circle.success { background: linear-gradient(135deg, #07c160, #4ad06e); }
.circle-text { margin-top: 16rpx; font-size: 32rpx; font-weight: 500; }

@keyframes pulse {
  0%, 100% { box-shadow: 0 12rpx 40rpx rgba(25, 137, 250, 0.3); }
  50%      { box-shadow: 0 12rpx 60rpx rgba(25, 137, 250, 0.6); }
}

.hint { text-align: center; padding: 0 40rpx; }
.alt-actions { padding: 80rpx 40rpx 40rpx; }
