<view class="page invite" wx:if="{{ info }}">
  <view class="hero">
    <view class="title">邀请好友 双方各得 ¥30</view>
    <view class="muted">好友首次下单成功，奖励自动到账</view>
  </view>
  <view class="card stat">
    <view class="stat-item"><view class="num">{{ info.invitedCount }}</view><view class="muted">已邀请</view></view>
    <view class="stat-item"><view class="num">¥{{ (info.rewardAmount / 100).toFixed(0) }}</view><view class="muted">已获奖励</view></view>
  </view>
  <view class="card code-card">
    <view class="muted">我的邀请码</view>
    <view class="code">{{ info.inviteCode }}</view>
    <van-button plain round size="small" bindtap="copyCode">复制邀请码</van-button>
  </view>
  <view class="actions">
    <button class="btn share" open-type="share">微信好友分享</button>
  </view>
</view>
