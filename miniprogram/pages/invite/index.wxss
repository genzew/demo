.invite { padding: 40rpx 0; }
.hero { text-align: center; padding: 24rpx; }
.hero .title { font-size: 40rpx; font-weight: 700; }
.stat { display: flex; padding: 24rpx 0; }
.stat-item { flex: 1; text-align: center; }
.stat-item .num { font-size: 44rpx; font-weight: 700; color: #ee0a24; }
.code-card { text-align: center; padding: 32rpx; }
.code { font-size: 60rpx; font-weight: 700; letter-spacing: 8rpx; margin: 16rpx 0; color: #1989fa; }
.actions { padding: 40rpx 32rpx; }
.btn.share {
  background: #07c160;
  color: #fff;
  border-radius: 50rpx;
  padding: 20rpx 0;
  font-weight: 500;
}
