<view class="page">
  <van-tabs active="{{ activeTab }}" bind:change="onTabChange">
    <van-tab wx:for="{{ tabs }}" wx:key="key" title="{{ item.name }}" />
  </van-tabs>
  <block wx:if="{{ list.length === 0 }}">
    <empty-state text="暂无优惠券" />
  </block>
  <view class="card coupon" wx:for="{{ list }}" wx:key="id">
    <view class="amount">
      <text class="symbol">¥</text>
      <text class="num">{{ (item.amount / 100).toFixed(0) }}</text>
    </view>
    <view class="info flex-1">
      <view class="title">{{ item.title }}</view>
      <view class="muted">{{ item.desc }}</view>
      <view class="muted">有效期至 {{ item.expireAt }}</view>
    </view>
  </view>
</view>
